<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Memory thoughts — TryGainMemory refreshes duration, does not stack. -->

  <ThoughtDef>
    <defName>RPR_BoughtPremiumFood</defName>
    <durationDays>1</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>purchased premium food</label>
        <description>I purchased premium food!</description>
        <baseMoodEffect>2</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>RPR_BoughtDrug</defName>
    <durationDays>3</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>purchased drug</label>
        <description>I purchased a drug!</description>
        <baseMoodEffect>5</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>RPR_AllowanceGood</defName>
    <durationDays>1</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>allowance sufficient</label>
        <description>Our allowance is really generous!</description>
        <baseMoodEffect>5</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

  <ThoughtDef>
    <defName>RPR_FeeExploitation</defName>
    <durationDays>1</durationDays>
    <stackLimit>1</stackLimit>
    <stages>
      <li>
        <label>fee exploitation</label>
        <description>Damn those managers......</description>
        <baseMoodEffect>-5</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>
</Defs>
