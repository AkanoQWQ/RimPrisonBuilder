<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- Prisoner interaction mode: allow labor -->
  <PrisonerInteractionModeDef>
    <defName>RimPrison_AllowLabor</defName>
    <label>Allow labor</label>
    <listOrder>5</listOrder>
    <isNonExclusiveInteraction>true</isNonExclusiveInteraction>
  </PrisonerInteractionModeDef>

  <!-- Inject prisoner labor ThinkTree -->
  <ThinkTreeDef>
    <defName>RimPrison_PrisonerLabor</defName>
    <insertTag>Humanlike_PostDuty</insertTag>
    <insertPriority>80</insertPriority>
    <thinkRoot Class="RimPrison.Core.ThinkNodes.ThinkNode_ConditionalPrisonerLabor">
      <subNodes>
        <li Class="ThinkNode_PrioritySorter">
          <subNodes>
            <li Class="JobGiver_GetRest" />
            <li Class="JobGiver_GetFood" />
            <li Class="RimPrison.Core.JobGiver_CouponShopBuy" />
            <li Class="JobGiver_Work" />
            <li Class="ThinkNode_Priority_GetJoy">
              <subNodes>
                <li Class="JobGiver_GetJoy" />
                <li Class="JobGiver_GetJoyInBed" />
              </subNodes>
            </li>
          </subNodes>
        </li>
      </subNodes>
    </thinkRoot>
  </ThinkTreeDef>

  <!-- Prisoner management tab -->
  <MainButtonDef>
    <defName>RimPrison_Prisoners</defName>
    <label>Prisoners</label>
    <tabWindowClass>RimPrison.MainTabWindow_Prisoners</tabWindowClass>
    <order>45</order>
  </MainButtonDef>

  <!-- WorkGiver: colonists deliver items to coupon shop -->
  <WorkGiverDef>
    <defName>RimPrison_CouponShopStore</defName>
    <label>stock coupon shop</label>
    <gerund>stocking coupon shop</gerund>
    <giverClass>RimPrison.Core.WorkGiver_CouponShopStore</giverClass>
    <priorityInType>10</priorityInType>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
    <verb>stock</verb>
    <workType>Hauling</workType>
  </WorkGiverDef>

  <!-- Job: colonist delivers item to coupon shop -->
  <JobDef>
    <defName>RimPrison_TakeToCouponShop</defName>
    <driverClass>RimPrison.Core.JobDriver_TakeToCouponShop</driverClass>
    <reportString>taking TargetA to TargetB.</reportString>
    <suspendable>false</suspendable>
  </JobDef>

  <!-- Job: prisoner buys item from coupon shop -->
  <JobDef>
    <defName>RimPrison_BuyFromCouponShop</defName>
    <driverClass>RimPrison.Core.JobDriver_BuyFromCouponShop</driverClass>
    <reportString>buying from TargetA.</reportString>
    <suspendable>false</suspendable>
  </JobDef>

</Defs>
