<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- Remove restrictions that prevent prisoners from having Joy need -->
  <Operation Class="PatchOperationRemove">
    <xpath>/Defs/NeedDef[defName="Joy"]/neverOnPrisoner</xpath>
  </Operation>
  <Operation Class="PatchOperationRemove">
    <xpath>/Defs/NeedDef[defName="Joy"]/colonistsOnly</xpath>
  </Operation>
</Patch>
