<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- Inject CompProperties_DoorAccess into all door defs.
       Matches: abstract bases (DoorBase, Door, Building_Door) + concrete doors via thingClass. -->
  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/ThingDef[thingClass='Building_Door' or @Name='DoorBase' or @ParentName='DoorBase' or @Name='Door' or @ParentName='Door']/comps</xpath>
    <value>
      <li Class="RimPrison.DoorAccess.CompProperties_DoorAccess" />
    </value>
  </Operation>
</Patch>
